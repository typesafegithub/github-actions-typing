{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:base"
  ],
  "automerge": true,
  "schedule": ["every 1 week on saturday"],
  "packageRules": [
    {
      "matchPackageNames": ["io.kotest.multiplatform"],
      "allowedVersions": "!/LOCAL$/"
    },
    {
      "groupName": "gradle-actions",
      "matchPackageNames": [
        "gradle/actions",
        "/^gradle:actions__.*$/"
      ]
    }
  ]
}
